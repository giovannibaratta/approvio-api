{
  "name": "@approvio/api",
  "author": "Giovanni Baratta",
  "license": "MIT",
  "version": "0.0.30",
  "private": false,
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/giovannibaratta/approvio-api"
  },
  "engines": {
    "node": "22"
  },
  "scripts": {
    "clean": "rm -rf dist generated/openapi/model generated/openapi/.openapi-generator generated/openapi.yaml",
    "bundle": "yarn redocly bundle openapi.yaml -o generated/openapi.yaml",
    "generate:api": "yarn clean && yarn bundle && openapi-generator-cli generate --openapitools openapitools.json",
    "lint": "yarn lint:code && yarn lint:api",
    "lint:code": "yarn eslint --cache --fix .",
    "lint:api": "spectral lint generated/openapi.yaml --ruleset .spectral.yaml",
    "build": "yarn generate:api && tsc -p tsconfig.json",
    "generate:docs": "yarn bundle && redocly build-docs generated/openapi.yaml --output ./dist/index.html",
    "prepublishOnly": "yarn build",
    "format:prettier": "yarn prettier --config .prettierrc . --write",
    "test": "yarn jest --maxWorkers=50%",
    "test:all": "yarn jest --maxWorkers=50% app/**/*.test.ts"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@openapitools/openapi-generator-cli": "^2.30.2",
    "@redocly/cli": "1.34.4",
    "@stoplight/spectral-cli": "6.15.0",
    "@types/jest": "30.0.0",
    "@typescript-eslint/eslint-plugin": "8.56.1",
    "@typescript-eslint/parser": "8.56.1",
    "eslint": "10.0.2",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-jest": "29.15.0",
    "eslint-plugin-n": "17.24.0",
    "eslint-plugin-prettier": "5.5.5",
    "jest": "30.2.0",
    "prettier": "3.8.1",
    "ts-jest": "29.4.6",
    "typescript": "5.7.3",
    "typescript-eslint": "8.56.1",
    "fp-ts": "2.16.11"
  },
  "packageManager": "yarn@1.22.22+sha512.a6b2f7906b721bba3d67d4aff083df04dad64c399707841b7acf00f6b133b7ac24255f2652fa22ae3534329dc6180534e98d17432037ff6fd140556e2bb3137e",
  "peerDependencies": {
    "fp-ts": "^2.0.0"
  }
}